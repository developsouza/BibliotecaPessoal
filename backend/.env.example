# =============================================================
# BookLibrary Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# =============================================================

# --- Servidor ---
PORT=3002
NODE_ENV=production

# --- JWT ---
JWT_SECRET=TROQUE_POR_UMA_CHAVE_ALEATORIA_FORTE_COM_32+_CHARS
JWT_EXPIRES_IN=7d

# --- Banco de Dados ---
DATABASE_PATH=./data/booklibrary.db

# --- Uploads ---
UPLOAD_PATH=./uploads

# --- URL do Frontend (CORS) ---
FRONTEND_URL=https://biblioteca.g3tsistemas.com.br

# --- Google Books API ---
GOOGLE_BOOKS_API_KEY=SUA_CHAVE_AQUI

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_SUA_CHAVE_LIVE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_SEU_SEGREDO_AQUI
STRIPE_PRICE_PREMIUM=price_ID_DO_PLANO_PREMIUM
STRIPE_PRICE_PRO=price_ID_DO_PLANO_PRO

# --- Master Admin (criado na 1ª inicialização) ---
MASTER_ADMIN_EMAIL=admin@g3tsistemas.com.br
MASTER_ADMIN_PASSWORD=SENHA_FORTE_AQUI
